name: AI Security Remediation

on:
  repository_dispatch:
    types: [jira-remediation]

jobs:
  remediation:
    runs-on: ubuntu-latest

    env:
      ISSUE_KEY: ${{ github.event.client_payload.issue }}

    permissions:
      contents: write
      pull-requests: write
      issues: write
      models: read 

    steps:

      - uses: actions/checkout@v4

      - name: Install Tools
        run: |
          sudo apt-get update
          sudo apt-get install -y jq

      - name: Install dependencies
        run: pip install -r requirements.txt

      # -------------------------------
      # NEW: Fetch Jira Attachment
      # -------------------------------
      - name: Get Jira Issue Details
        run: |
          curl -s \
            -u "${{ secrets.JIRA_EMAIL }}:${{ secrets.JIRA_API_TOKEN }}" \
            -H "Accept: application/json" \
            ${{ secrets.JIRA_URL }}/rest/api/3/issue/$ISSUE_KEY \
            > issue.json

      - name: Extract Attachment URL
        run: |
          ATTACH_URL=$(jq -r '
            .fields.attachment[]
            | select(.filename=="scan_payload.json")
            | .content
          ' issue.json)

          echo "ATTACH_URL=$ATTACH_URL" >> $GITHUB_ENV

      - name: Download Snyk Report or Fallback
        run: |
          if [ -z "$ATTACH_URL" ] || [ "$ATTACH_URL" == "null" ]; then
            echo "No attachment found. Running Snyk scan..."
            # snyk code test --json > snyk.json || true
          else
            echo "Downloading Snyk report from Jira..."
            curl -L \
              -u "${{ secrets.JIRA_EMAIL }}:${{ secrets.JIRA_API_TOKEN }}" \
              -o snyk.json \
              "$ATTACH_URL"
          fi

      # ── Create fix branch ────────────────────────────────────────────────
      - name: Create Fix Branch
        run: |
          BRANCH="security/fix-$ISSUE_KEY-${{ github.run_id }}"
          git checkout -b "$BRANCH"
          echo "BRANCH=$BRANCH" >> $GITHUB_ENV

      # -------------------------------
      # Process  and fix vulnerabilities
      # -------------------------------
      
      - name: Fix Dependencies
        run: |
          python .github/scripts/fix_dependencies.py snyk.json pom.xml

      - name: Print updated pom.xml
        run: cat pom.xml

      # ═════════════════════════════════════════════════════════════
      # SELF-HEALING BUILD LOOP (Max 5 iterations)
      # ═════════════════════════════════════════════════════════════
      - name: Self-Healing Build (AI Loop)
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          MAX_RETRIES=5
          COUNT=1

          while [ $COUNT -le $MAX_RETRIES ]
          do
            echo "════════════════════════════════════════════"
            echo "🔁 ITERATION $COUNT"
            echo "════════════════════════════════════════════"

            # Step 1: Compile
            mvn clean compile 2>&1 | tee build.log || true

            if grep -q "BUILD SUCCESS" build.log; then
              echo "✅ Build succeeded at iteration $COUNT"
              exit 0
            fi

            ERROR_COUNT=$(grep -c "\[ERROR\].*\.java:" build.log || echo 0)
            echo "❌ Build failed with $ERROR_COUNT errors"

            # Step 2: Run Fix Agent
            echo "🤖 Running AI Fix Agent..."
            python .github/scripts/fix_imports.py build.log pom.xml src/

            echo "🛠 Fix applied. Retrying build..."

            COUNT=$((COUNT+1))
          done

          echo "🚨 Build failed after $MAX_RETRIES attempts"


      - name: Fix Code Vulnerabilities with AI
        if: failure() || success()  # Always run after compile attempt
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          python .github/scripts/fix_code_vulnerabilities.py snyk.json

      # ═════════════════════════════════════════════════════════════
      # SELF-HEALING BUILD LOOP (Max 5 iterations)
      # ═════════════════════════════════════════════════════════════
      - name: Self-Healing Build (AI Loop)
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          MAX_RETRIES=5
          COUNT=1

          while [ $COUNT -le $MAX_RETRIES ]
          do
            echo "════════════════════════════════════════════"
            echo "🔁 ITERATION $COUNT"
            echo "════════════════════════════════════════════"

            # Step 1: Compile
            mvn clean compile 2>&1 | tee build.log || true

            if grep -q "BUILD SUCCESS" build.log; then
              echo "✅ Build succeeded at iteration $COUNT"
              exit 0
            fi

            ERROR_COUNT=$(grep -c "\[ERROR\].*\.java:" build.log || echo 0)
            echo "❌ Build failed with $ERROR_COUNT errors"

            # Step 2: Run Fix Agent
            echo "🤖 Running AI Fix Agent..."
            python .github/scripts/fix_imports.py build.log pom.xml src/

            echo "🛠 Fix applied. Retrying build..."

            COUNT=$((COUNT+1))
          done

          echo "🚨 Build failed after $MAX_RETRIES attempts"

      

      - name: Commit Fix
        run: |
          git config user.name security-bot
          git config user.email bot@users.noreply.github.com
          git add .
          git commit -m "AI security remediation" || echo "No changes to commit"
          git push origin HEAD

      - name: Create PR
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          PR_URL=$(gh pr create \
            --title "AI Security Remediation" \
            --body "Automated security remediation." \
            --base main \
            --head $BRANCH)

          PR_NUMBER=$(echo $PR_URL | grep -o '[0-9]*$')
          echo "PR=$PR_NUMBER" >> $GITHUB_ENV


