name: AI Security Remediation

on:
  repository_dispatch:
    types: [jira-remediation]

jobs:
  remediation:
    runs-on: ubuntu-latest

    env:
      ISSUE_KEY: ${{ github.event.client_payload.issue }}

    permissions:
      contents: write
      pull-requests: write
      issues: write
      models: read 

    steps:

      - uses: actions/checkout@v4

      - name: Install Tools
        run: |
          sudo apt-get update
          sudo apt-get install -y jq
          npm install -g snyk

      - name: Install dependencies
        run: pip install -r requirements.txt

      - name: Snyk Auth
        run: snyk auth ${{ secrets.SNYK_TOKEN }}

      # -------------------------------
      # NEW: Fetch Jira Attachment
      # -------------------------------
      - name: Get Jira Issue Details
        run: |
          curl -s \
            -u "${{ secrets.JIRA_EMAIL }}:${{ secrets.JIRA_API_TOKEN }}" \
            -H "Accept: application/json" \
            ${{ secrets.JIRA_URL }}/rest/api/3/issue/$ISSUE_KEY \
            > issue.json

      - name: Extract Attachment URL
        run: |
          ATTACH_URL=$(jq -r '
            .fields.attachment[]
            | select(.filename=="scan_payload.json")
            | .content
          ' issue.json)

          echo "ATTACH_URL=$ATTACH_URL" >> $GITHUB_ENV

      - name: Download Snyk Report or Fallback
        run: |
          if [ -z "$ATTACH_URL" ] || [ "$ATTACH_URL" == "null" ]; then
            echo "No attachment found. Running Snyk scan..."
            snyk code test --json > snyk.json || true
          else
            echo "Downloading Snyk report from Jira..."
            curl -L \
              -u "${{ secrets.JIRA_EMAIL }}:${{ secrets.JIRA_API_TOKEN }}" \
              -o snyk.json \
              "$ATTACH_URL"
          fi

      # -------------------------------
      # Process  and fix vulnerabilities
      # -------------------------------
      
      - name: Fix Dependencies
        run: |
          python .github/scripts/fix_dependencies.py snyk.json

      - name: Compile Project
        id: compile
        run: |
          set -e
          mvn clean compile
        continue-on-error: true

      - name: Fix Code Vulnerabilities with AI
        if: failure() || success()  # Always run after compile attempt
        env:
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
        run: |
          python .github/scripts/fix_code_vulnerabilities.py snyk.json
      - name: Recompile After Fixes
        run: |
          mvn clean compile


      - name: Extract Vulnerable Files
        run: |
          jq -r '
            .runs[].results[]
            | .locations[0].physicalLocation.artifactLocation.uri
          ' snyk.json | sort -u > files.txt

      - name: Create Fix Branch
        run: |
          BRANCH="security/remediation-${{ github.run_id }}"
          git checkout -b $BRANCH
          echo "BRANCH=$BRANCH" >> $GITHUB_ENV

      # -------------------------------
      # AI Fix
      # -------------------------------
      - name: AI Patch Files with Snyk Context
        run: |
          while read FILE
          do
            if [ ! -f "$FILE" ]; then
              echo "Skipping missing file: $FILE"
              continue
            fi

            CODE=$(cat "$FILE")

            VULNS=$(jq -c --arg file "$FILE" '
              [.runs[].results[]
              | select(.locations[0].physicalLocation.artifactLocation.uri==$file)]
            ' snyk.json)

            JSON=$(jq -n \
              --arg code "$CODE" \
              --argjson vulns "$VULNS" \
              '{
                model: "gpt-4o-mini",
                messages: [
                  {
                    role: "system",
                    content: "You are a senior Java security engineer. Output ONLY pure Java source code as plain text. Do NOT wrap in quotes, code blocks, or markdown. Do NOT include explanations."
                  },
                  {
                    role: "user",
                    content: (
                      "Refactor this Java code to fix security vulnerabilities. STRICT REQUIREMENTS:\n" +
                      "1. Do NOT change business logic.\n" +
                      "2. Do NOT add extra code.\n" +
                      "3. Only fix issues reported in the Snyk report.\n" +
                      "4. Keep variable/method names and structure.\n" +
                      "5. Ensure code compiles and runs.\n" +
                      "6. Keep input/output behavior identical.\n" +
                      "Here is the file data:\n" +
                      "{\"code\": " + ($code|@json) + ", \"vulnerabilities\": " + ($vulns|@json) + "}"
                    )
                  }
                ]
              }')

            RESPONSE=$(curl -s -X POST \
              https://models.github.ai/inference/chat/completions \
              -H "Authorization: Bearer ${{ secrets.GITHUB_TOKEN }}" \
              -H "Content-Type: application/json" \
              -d "$JSON")

            NEW_CODE=$(echo "$RESPONSE" | jq -r '.choices[0].message.content')

            echo "$NEW_CODE" > "$FILE"

          done < files.txt

      - name: Commit Fix
        run: |
          git config user.name security-bot
          git config user.email bot@users.noreply.github.com
          git add .
          git commit -m "AI security remediation" || echo "No changes to commit"
          git push origin HEAD

      - name: Create PR
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          PR_URL=$(gh pr create \
            --title "AI Security Remediation" \
            --body "Automated security remediation." \
            --base main \
            --head $BRANCH)

          PR_NUMBER=$(echo $PR_URL | grep -o '[0-9]*$')
          echo "PR=$PR_NUMBER" >> $GITHUB_ENV

      - name: Update Jira status to Review
        run: |
          curl \
          -u "${{ secrets.JIRA_EMAIL }}:${{ secrets.JIRA_API_TOKEN }}" \
          -H "Content-Type: application/json" \
          -X POST \
          --data '{
            "transition": {
              "id": "4"
            }
          }' \
          ${{ secrets.JIRA_URL }}/rest/api/3/issue/$ISSUE_KEY/transitions

      - name: Generate GitHub Summary
        if: always()
        run: |
          TOTAL=$(jq '.runs[0].results | length' snyk.json 2>/dev/null || echo 0)
          FILES_FIXED=$(cat files.txt 2>/dev/null | wc -l | tr -d ' ')

          {
            echo "## 🛠️ AI Security Remediation Summary"
            echo ""

            if [ "$TOTAL" -eq 0 ]; then
              echo "✅ **No vulnerabilities required remediation.**"
            else
              HIGH=$(jq '[.runs[0].results[] | select(.level=="error")] | length' snyk.json)
              MEDIUM=$(jq '[.runs[0].results[] | select(.level=="warning")] | length' snyk.json)
              LOW=$(jq '[.runs[0].results[] | select(.level=="note")] | length' snyk.json)

              echo "| Metric | Value |"
              echo "|--------|-------|"
              echo "| 🔴 High vulnerabilities | $HIGH |"
              echo "| 🟡 Medium vulnerabilities | $MEDIUM |"
              echo "| 🔵 Low vulnerabilities | $LOW |"
              echo "| **Total vulnerabilities** | **$TOTAL** |"
              echo "| 📁 Files patched | $FILES_FIXED |"
              echo ""
              echo "### Vulnerabilities Remediated"
              echo ""
              echo "| # | Rule ID | Severity | File | Line | Description |"
              echo "|---|---------|----------|------|------|-------------|"

              jq -r '
                .runs[0].results[] |
                [
                  .ruleId // "N/A",
                  (.level // "note"),
                  (.locations[0].physicalLocation.artifactLocation.uri // "N/A"),
                  (.locations[0].physicalLocation.region.startLine // "N/A" | tostring),
                  (.message.text // "N/A" | gsub("\n"; " ") | .[0:100])
                ] | @tsv
              ' snyk.json | awk -F'\t' 'BEGIN{i=1} {
                sev=$2
                if (sev=="error") emoji="🔴 High"
                else if (sev=="warning") emoji="🟡 Medium"
                else emoji="🔵 Low"
                printf "| %d | `%s` | %s | `%s` | %s | %s |\n", i, $1, emoji, $3, $4, $5
                i++
              }'

              echo ""
              echo "---"
              echo ""

              if [ -n "$PR" ]; then
                PR_URL="https://github.com/${{ github.repository }}/pull/$PR"
                echo "🔀 **Pull Request**: [PR #$PR]($PR_URL)"
                echo ""
              fi

              JIRA_URL_BROWSE="${{ secrets.JIRA_URL }}/browse/$ISSUE_KEY"
              echo "🎫 **Jira Ticket**: [$ISSUE_KEY]"
            fi
          } >> $GITHUB_STEP_SUMMARY